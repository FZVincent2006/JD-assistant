{
  "manifest_version": 3,
  "name": "招聘 JD 发布助手",
  "description": "解析招聘 JD，自动填入 Boss、脉脉或指定飞书招聘测试文档，并在写入前保留人工确认。",
  "version": "0.2.0",
  "key": "",
  "permissions": ["activeTab", "identity", "scripting", "sidePanel", "storage", "tabs", "webNavigation"],
  "host_permissions": [
    "https://*.zhipin.com/*",
    "https://*.kanzhun.com/*",
    "https://maimai.cn/*",
    "https://*.maimai.cn/*",
    "https://maimai.com/*",
    "https://*.maimai.com/*",
    "https://accounts.feishu.cn/*",
    "https://open.feishu.cn/*"
  ],
  "action": {
    "default_title": "打开招聘 JD 发布助手"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.zhipin.com/*",
        "https://*.kanzhun.com/*",
        "https://maimai.cn/*",
        "https://*.maimai.cn/*",
        "https://maimai.com/*",
        "https://*.maimai.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
